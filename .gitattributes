# Force LF line endings — Theos Makefiles require tabs + LF (CRLF breaks gmake).
* text=auto eol=lf

# Makefiles are especially sensitive to line-ending corruption
Makefile       text eol=lf
Makefile.dylib text eol=lf

# Sources
*.x  text eol=lf
*.m  text eol=lf
*.h  text eol=lf

# Plain text config / docs
*.plist   text eol=lf
control   text eol=lf
*.sh      text eol=lf
*.yml     text eol=lf
*.md      text eol=lf
LICENSE   text eol=lf
.gitignore text eol=lf

# Binaries (never normalize)
*.dylib binary
*.deb   binary
*.png   binary
